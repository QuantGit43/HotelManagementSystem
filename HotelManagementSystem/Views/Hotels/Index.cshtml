@model IEnumerable<HotelManagementSystem.Models.Hotel>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.HtName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HtAddress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HtStars)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.HtName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HtAddress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HtStars)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.HtId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.HtId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.HtId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
