@model HotelManagementSystem.Models.Booking

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>Booking</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="BkId" />
            <div class="form-group">
                <label asp-for="BkDateIn" class="control-label"></label>
                <input asp-for="BkDateIn" class="form-control" />
                <span asp-validation-for="BkDateIn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BkDateOut" class="control-label"></label>
                <input asp-for="BkDateOut" class="form-control" />
                <span asp-validation-for="BkDateOut" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BkClId" class="control-label"></label>
                <select asp-for="BkClId" class="form-control" asp-items="ViewBag.BkClId"></select>
                <span asp-validation-for="BkClId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BkRmId" class="control-label"></label>
                <select asp-for="BkRmId" class="form-control" asp-items="ViewBag.BkRmId"></select>
                <span asp-validation-for="BkRmId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
